# LLM and search
SERPAPI_API_KEY=your_serpapi_key
OPENAI_API_KEY=your_openai_compatible_key
OPENAI_API_BASE=https://your-openai-compatible-base/v1

# Primary and fallback models
BASE_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_API_BASE=https://api.siliconflow.cn/v1
BACKUP_MODEL=deepseek-ai/DeepSeek-V2.5

# Embeddings and vector store
EMBEDDING_MODEL=Pro/BAAI/bge-m3
EMBEDDING_API_KEY=your_embedding_key
EMBEDDING_API_BASE=https://api.siliconflow.cn/v1
EMBEDDING_COLLECTION=aihelper_documents
PERSIST_DIR=./vector_db
CHUNK_SIZE=800
CHUNK_OVERLAP=50
MEMORY_KEY=chat_history

# Redis
REDIS_URL=redis://localhost:6379/0

# DingTalk
DINGDING_ID=your_dingtalk_app_key
DINGDING_SECRET=your_dingtalk_app_secret
DINGDING_UNION_ID=your_dingtalk_union_id
DINGDING_TARGET_USERID=your_target_user_id
DINGDING_ROBOT_CODE=your_robot_code
